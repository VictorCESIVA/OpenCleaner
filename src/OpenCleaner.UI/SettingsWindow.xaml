<Window x:Class="OpenCleaner.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paramètres — Planificateur automatique"
        Height="620" Width="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <SolidColorBrush x:Key="BgMain"      Color="#1C1C1C"/>
        <SolidColorBrush x:Key="BgCard"      Color="#252525"/>
        <SolidColorBrush x:Key="BgHover"     Color="#2D2D2D"/>
        <SolidColorBrush x:Key="Accent"      Color="#0078D4"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecond"  Color="#ABABAB"/>
        <SolidColorBrush x:Key="Border"      Color="#333333"/>

        <!-- Bouton Accent -->
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1084D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox minimaliste -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BgMain}">
        <Grid Margin="28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- EN-TÊTE -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="⚙️  Paramètres"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="Planificateur de nettoyage automatique via le Planificateur de tâches Windows."
                           FontSize="12" Foreground="{DynamicResource TextSecond}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- SECTION : Activer / Désactiver -->
            <Border Grid.Row="1" Background="{DynamicResource BgCard}" CornerRadius="10"
                    Padding="20,14" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Nettoyage automatique"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <CheckBox x:Name="EnabledCheck"
                              Content="Activer le nettoyage automatique"
                              Checked="EnabledCheck_Changed"
                              Unchecked="EnabledCheck_Changed"/>
                    <TextBlock Text="Crée une tâche dans le Planificateur de tâches Windows."
                               FontSize="11" Foreground="{DynamicResource TextSecond}"
                               Margin="20,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- SECTION : Heure -->
            <Border Grid.Row="2" Background="{DynamicResource BgCard}" CornerRadius="10"
                    Padding="20,14" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Heure de lancement"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="TimeBox"
                                 Text="03:00"
                                 Width="80" Height="34"
                                 Background="#1A1A1A"
                                 Foreground="White"
                                 BorderBrush="{DynamicResource Border}"
                                 Padding="8,6"
                                 FontSize="14"
                                 CaretBrush="White"/>
                        <TextBlock Text="(format HH:mm)"
                                   FontSize="11" Foreground="{DynamicResource TextSecond}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- SECTION : Jours -->
            <Border Grid.Row="3" Background="{DynamicResource BgCard}" CornerRadius="10"
                    Padding="20,14" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Jours de la semaine"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <CheckBox x:Name="DayMon" Content="Lun" Tag="Monday"    Margin="0,4,16,4"/>
                        <CheckBox x:Name="DayTue" Content="Mar" Tag="Tuesday"   Margin="0,4,16,4"/>
                        <CheckBox x:Name="DayWed" Content="Mer" Tag="Wednesday" Margin="0,4,16,4"/>
                        <CheckBox x:Name="DayThu" Content="Jeu" Tag="Thursday"  Margin="0,4,16,4"/>
                        <CheckBox x:Name="DayFri" Content="Ven" Tag="Friday"    Margin="0,4,16,4"/>
                        <CheckBox x:Name="DaySat" Content="Sam" Tag="Saturday"  Margin="0,4,16,4"/>
                        <CheckBox x:Name="DaySun" Content="Dim" Tag="Sunday"    Margin="0,4,16,4"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- SECTION : Plugins -->
            <Border Grid.Row="4" Background="{DynamicResource BgCard}" CornerRadius="10"
                    Padding="20,14" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Plugins à exécuter automatiquement"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <CheckBox x:Name="PlugSystem"  Content="🧹 Fichiers temporaires" Tag="system.temp"       Margin="0,4,20,4"/>
                        <CheckBox x:Name="PlugWinUpd"  Content="🪟 Windows Update"       Tag="system.windowsupdate"  Margin="0,4,20,4"/>
                        <CheckBox x:Name="PlugBrowser" Content="🌐 Navigateurs"          Tag="browser.chrome"    Margin="0,4,20,4"/>
                        <CheckBox x:Name="PlugThumb"   Content="🖼️ Miniatures"           Tag="system.thumbnailcache" Margin="0,4,20,4"/>
                        <CheckBox x:Name="PlugOffice"  Content="📄 Office"               Tag="applications.office"     Margin="0,4,20,4"/>
                        <CheckBox x:Name="PlugSteam"   Content="🎮 Steam"                Tag="games.steam"      Margin="0,4,20,4"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- SPACER -->
            <Grid Grid.Row="5"/>

            <!-- BARRE ACTIONS -->
            <Border Grid.Row="6" Background="{DynamicResource BgCard}" CornerRadius="10"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="SaveStatus"
                               Text="" Foreground="{DynamicResource TextSecond}"
                               VerticalAlignment="Center" FontSize="12"/>
                    <Button Grid.Column="1" Content="💾  Sauvegarder"
                            Style="{StaticResource AccentBtn}"
                            Click="Save_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
