<Window x:Class="OpenCleaner.UI.RestoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restauration des fichiers" Height="500" Width="700">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🛡️ Restauration" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
        <TextBlock Grid.Row="1" Text="Sélectionnez un backup à restaurer :" Margin="0,0,0,10"/>

        <ListView Grid.Row="2" x:Name="BackupsListView" SelectionChanged="BackupsListView_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Date" DisplayMemberBinding="{Binding CreatedAt}" Width="120"/>
                    <GridViewColumn Header="Fichier original" DisplayMemberBinding="{Binding OriginalPath}" Width="350"/>
                    <GridViewColumn Header="Taille" DisplayMemberBinding="{Binding Size, StringFormat={}{0:N0} octets}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="RefreshBtn" Content="🔄 Rafraîchir" Click="Refresh_Click" Padding="15,8" Margin="0,0,10,0"/>
            <Button x:Name="RestoreBtn" Content="↩️ Restaurer" Click="Restore_Click" Padding="15,8" IsEnabled="False"/>
            <Button x:Name="DeleteOldBtn" Content="🗑️ Supprimer vieux (>30j)" Click="DeleteOld_Click" Padding="15,8" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
