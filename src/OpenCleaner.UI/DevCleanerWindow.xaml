<Window x:Class="OpenCleaner.UI.DevCleanerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dev Cleaner" Height="720" Width="900"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="BgMain"    Color="#1C1C1C"/>
        <SolidColorBrush x:Key="BgCard"    Color="#252525"/>
        <SolidColorBrush x:Key="BgHover"   Color="#2D2D2D"/>
        <SolidColorBrush x:Key="Accent"    Color="#0078D4"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecond"  Color="#ABABAB"/>
        <SolidColorBrush x:Key="Border"    Color="#333333"/>
        <SolidColorBrush x:Key="WarnColor" Color="#FF8C00"/>

        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1084D9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BgMain}">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- EN-TÊTE -->
            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="🧑‍💻  Dev Cleaner"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="Nettoie les caches et artefacts liés au développement : node_modules, npm, VS Code, Discord, JetBrains…"
                           FontSize="12" Foreground="{DynamicResource TextSecond}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- SÉLECTION CATÉGORIES + WARNING DOCKER -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource BgCard}" CornerRadius="10"
                        Padding="20,14" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Catégories à analyser"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <CheckBox x:Name="CbNode"    Content="📦 node_modules orphelins" IsChecked="True" Margin="0,5,24,5"/>
                            <CheckBox x:Name="CbNpm"     Content="🟩 Cache npm"              IsChecked="True" Margin="0,5,24,5"/>
                            <CheckBox x:Name="CbYarn"    Content="🧶 Cache yarn"             IsChecked="True" Margin="0,5,24,5"/>
                            <CheckBox x:Name="CbVsCode"  Content="🔵 VS Code"                IsChecked="True" Margin="0,5,24,5"/>
                            <CheckBox x:Name="CbDiscord" Content="🎮 Discord"                IsChecked="True" Margin="0,5,24,5"/>
                            <CheckBox x:Name="CbSpotify" Content="🟢 Spotify"               IsChecked="True" Margin="0,5,24,5"/>
                            <CheckBox x:Name="CbJetBrains" Content="🧠 JetBrains"            IsChecked="True" Margin="0,5,24,5"/>
                            <CheckBox x:Name="CbDocker"  Content="🐳 Docker"                 IsChecked="False" Margin="0,5,24,5"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- WARNING Docker + Stats -->
                <StackPanel Grid.Column="1">
                    <Border Background="#2A1A00" CornerRadius="10" Padding="14,12" Margin="0,0,0,8"
                            BorderBrush="{DynamicResource WarnColor}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="⚠️  Docker Desktop"
                                       FontWeight="Bold" FontSize="13"
                                       Foreground="{DynamicResource WarnColor}"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,6,0,0"
                                       Foreground="#FFB860"
                                       Text="Fermez Docker Desktop avant d'activer le nettoyage Docker. Les contextes non-default seront supprimés."/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource BgCard}" CornerRadius="10" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="Espace libérable"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecond}"/>
                            <TextBlock x:Name="EstimateText" Text="—"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="{DynamicResource Accent}"
                                       Margin="0,6,0,0"/>
                            <TextBlock x:Name="EstimateDetail" Text=""
                                       FontSize="11" TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecond}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- LISTE RÉSULTATS -->
            <Border Grid.Row="2" Background="{DynamicResource BgCard}" CornerRadius="10" Padding="0">
                <ListView x:Name="ResultList"
                          Background="Transparent"
                          BorderThickness="0"
                          Foreground="{DynamicResource TextPrimary}"
                          FontSize="12"
                          SelectionMode="Multiple">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="☑" Width="40">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Background="Transparent"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Catégorie" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Category}"
                                                   Foreground="{DynamicResource Accent}"
                                                   FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Taille" Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SizeLabel}" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Chemin / description" Width="580">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding PathLabel}"
                                                   Foreground="{DynamicResource TextSecond}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <!-- ACTIONS -->
            <Border Grid.Row="3" Background="{DynamicResource BgCard}" CornerRadius="10"
                    Padding="16,12" Margin="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="StatusText"
                               Text="Sélectionnez les catégories et cliquez Analyser."
                               Foreground="{DynamicResource TextSecond}"
                               VerticalAlignment="Center" FontSize="12"/>
                    <Button Grid.Column="1" Content="✓ Tout sélectionner"
                            Click="SelectAll_Click"
                            Background="Transparent" Foreground="{DynamicResource TextSecond}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1"
                            Padding="12,8" Cursor="Hand" Margin="0,0,8,0"
                            x:Name="SelectAllBtn" IsEnabled="False"/>
                    <Button Grid.Column="2" Content="🔍  Analyser"
                            Style="{StaticResource AccentBtn}"
                            Click="Scan_Click" x:Name="ScanBtn"
                            Margin="0,0,10,0"/>
                    <Button Grid.Column="3" Content="🗑  Nettoyer sélectionnés"
                            Style="{StaticResource AccentBtn}"
                            Click="Clean_Click"
                            x:Name="CleanBtn" IsEnabled="False"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
