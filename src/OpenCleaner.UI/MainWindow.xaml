<Window x:Class="OpenCleaner.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OpenCleaner.UI"
        Title="OpenCleaner" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        x:Name="RootWindow">

    <Window.Resources>

        <!-- ═══════════════════════════════════════════════════════
             COULEURS DE THÈME  (overridées dynamiquement depuis le code-behind)
        ═══════════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="BgMain"       Color="#1C1C1C"/>
        <SolidColorBrush x:Key="BgSidebar"    Color="#161616"/>
        <SolidColorBrush x:Key="BgCard"       Color="#252525"/>
        <SolidColorBrush x:Key="BgHover"      Color="#2D2D2D"/>
        <SolidColorBrush x:Key="BgSelected"   Color="#0078D4"/>
        <SolidColorBrush x:Key="Accent"       Color="#0078D4"/>
        <SolidColorBrush x:Key="AccentHover"  Color="#1084D9"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecond"   Color="#ABABAB"/>
        <SolidColorBrush x:Key="Border"       Color="#333333"/>

        <!-- Risque -->
        <SolidColorBrush x:Key="RiskSafe"        Color="#107C10"/>
        <SolidColorBrush x:Key="RiskRecommended" Color="#FF8C00"/>
        <SolidColorBrush x:Key="RiskExpert"      Color="#D13438"/>

        <!-- ═══════════════════════════════════════════════════════
             STYLE SIDEBAR BUTTON
        ═══════════════════════════════════════════════════════ -->
        <Style x:Key="SidebarBtnStyle" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="16,12"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Margin="6,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource BgSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SIDEBAR BUTTON SELECTIONNÉ -->
        <Style x:Key="SidebarBtnActiveStyle" TargetType="Button" BasedOn="{StaticResource SidebarBtnStyle}">
            <Setter Property="Background" Value="{DynamicResource BgSelected}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             STYLE BOUTON ACCENT (Analyser / Nettoyer)
        ═══════════════════════════════════════════════════════ -->
        <Style x:Key="AccentBtnStyle" TargetType="Button">
            <Setter Property="Background"   Value="{DynamicResource Accent}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="22,10"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Opacity="{TemplateBinding Opacity}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- BOUTON SECONDAIRE -->
        <Style x:Key="SecondBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="18,10"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             SCROLLBAR MINIMALISTE
        ═══════════════════════════════════════════════════════ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"       Value="6"/>
            <Setter Property="Background"  Value="Transparent"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════
             LISTVIEW ITEM STYLE (hover, select)
        ═══════════════════════════════════════════════════════ -->
        <Style x:Key="FileListItemStyle" TargetType="ListViewItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="Margin"          Value="0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background"
                                        Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bg" Property="Background"
                                        Value="{DynamicResource BgSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GRIDVIEW HEADER STYLE -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="{DynamicResource TextSecond}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="8,6"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
        </Style>

        <!-- ProgressBar moderne -->
        <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
            <Setter Property="Height"           Value="3"/>
            <Setter Property="Background"       Value="{DynamicResource Border}"/>
            <Setter Property="Foreground"       Value="{DynamicResource Accent}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="2"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="2"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Animations fade-in résultats -->
        <Storyboard x:Key="FadeInStory">
            <DoubleAnimation Storyboard.TargetName="ResultsPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35"/>
        </Storyboard>

    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════
         FOND PRINCIPAL
    ═══════════════════════════════════════════════════════════ -->
    <Border Background="{DynamicResource BgMain}">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Sidebar -->
                <ColumnDefinition Width="230"/>
                <!-- Contenu principal -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════════
                 SIDEBAR
            ═══════════════════════════════════════════════ -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BgSidebar}"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="0,0,1,0">
                <DockPanel>

                    <!-- LOGO / HEADER -->
                    <StackPanel DockPanel.Dock="Top" Margin="18,24,18,20">
                        <TextBlock Text="OpenCleaner"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Nettoyeur système"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecond}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- SEPARATEUR -->
                    <Border DockPanel.Dock="Top"
                            Height="1"
                            Background="{DynamicResource Border}"
                            Margin="12,0,12,10"/>

                    <!-- LABEL SECTION -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="SYSTÈME"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecond}"
                               Margin="22,8,0,4"/>

                    <!-- BOUTONS PLUGINS -->
                    <StackPanel DockPanel.Dock="Top" x:Name="SidebarPanel">

                        <Button x:Name="BtnSystem" Tag="system"
                                Style="{StaticResource SidebarBtnActiveStyle}"
                                Click="SidebarPlugin_Click">
                            <TextBlock Text="🧹  Fichiers temporaires"/>
                        </Button>

                        <Button x:Name="BtnWindowsUpdate" Tag="windowsupdate"
                                Style="{StaticResource SidebarBtnStyle}"
                                Click="SidebarPlugin_Click">
                            <TextBlock Text="🪟  Windows Update"/>
                        </Button>

                        <Button x:Name="BtnThumbnails" Tag="thumbnails"
                                Style="{StaticResource SidebarBtnStyle}"
                                Click="SidebarPlugin_Click">
                            <TextBlock Text="🖼️  Cache miniatures"/>
                        </Button>

                        <!-- SEPARATEUR -->
                        <Border Height="1" Background="{DynamicResource Border}" Margin="12,10"/>

                        <TextBlock Text="APPLICATIONS"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecond}"
                                   Margin="16,0,0,4"/>

                        <Button x:Name="BtnBrowser" Tag="browser"
                                Style="{StaticResource SidebarBtnStyle}"
                                Click="SidebarPlugin_Click">
                            <TextBlock Text="🌐  Chrome / Edge / Brave"/>
                        </Button>

                        <Button x:Name="BtnSteam" Tag="steam"
                                Style="{StaticResource SidebarBtnStyle}"
                                Click="SidebarPlugin_Click">
                            <TextBlock Text="🎮  Steam"/>
                        </Button>

                        <Button x:Name="BtnOffice" Tag="office"
                                Style="{StaticResource SidebarBtnStyle}"
                                Click="SidebarPlugin_Click">
                            <TextBlock Text="📄  Microsoft Office"/>
                        </Button>

                        <!-- SEPARATEUR -->
                        <Border Height="1" Background="{DynamicResource Border}" Margin="12,10"/>

                        <TextBlock Text="EXPERT"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecond}"
                                   Margin="16,0,0,4"/>

                        <Button x:Name="BtnRegistry" Tag="registry"
                                Style="{StaticResource SidebarBtnStyle}"
                                Click="SidebarPlugin_Click">
                            <TextBlock Text="⚠️  Registre Windows"/>
                        </Button>

                    </StackPanel>

                    <!-- BAS DE SIDEBAR : boutons utilitaires -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,16">
                        <Border Height="1" Background="{DynamicResource Border}" Margin="4,0,4,10"/>
                        <Button Style="{StaticResource SidebarBtnStyle}"
                                Click="OpenDuplicates_Click">
                            <TextBlock Text="🔁  Doublons"/>
                        </Button>
                        <Button Style="{StaticResource SidebarBtnStyle}"
                                Click="OpenRestore_Click">
                            <TextBlock Text="🛡️  Restauration"/>
                        </Button>
                        <Button Style="{StaticResource SidebarBtnStyle}"
                                Click="OpenDiskAnalyzer_Click">
                            <TextBlock Text="🗺️  Analyse Disque"/>
                        </Button>
                        <Button Style="{StaticResource SidebarBtnStyle}"
                                Click="OpenPrivacy_Click">
                            <TextBlock Text="🔒  Privacy"/>
                        </Button>
                        <Button Style="{StaticResource SidebarBtnStyle}"
                                Click="OpenDevCleaner_Click">
                            <TextBlock Text="🧑‍💻  Dev Tools"/>
                        </Button>
                        <Button Style="{StaticResource SidebarBtnStyle}"
                                Click="OpenSettings_Click">
                            <TextBlock Text="⚙️  Paramètres"/>
                        </Button>
                        <Button x:Name="ThemeToggleBtn"
                                Style="{StaticResource SidebarBtnStyle}"
                                Click="ThemeToggle_Click">
                            <TextBlock x:Name="ThemeIcon" Text="☀️  Thème clair"/>
                        </Button>
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════
                 ZONE PRINCIPALE
            ═══════════════════════════════════════════════ -->
            <Grid Grid.Column="1" Margin="28,24,28,20">
                <Grid.RowDefinitions>
                    <!-- Card Smart Clean -->
                    <RowDefinition Height="Auto"/>
                    <!-- Header plugin sélectionné -->
                    <RowDefinition Height="Auto"/>
                    <!-- Options navigateur (visible si plugin browser) -->
                    <RowDefinition Height="Auto"/>
                    <!-- Barre de stats (card) -->
                    <RowDefinition Height="Auto"/>
                    <!-- Progress bar fine -->
                    <RowDefinition Height="Auto"/>
                    <!-- ListView résultats -->
                    <RowDefinition Height="*"/>
                    <!-- Barre d'actions bas -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ⚡ SMART CLEAN CARD -->
                <Border Grid.Row="0" Margin="0,0,0,14"
                        CornerRadius="12"
                        Padding="20,14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0D5C26" Offset="0"/>
                            <GradientStop Color="#107C10" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="⚡  Smart Clean"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock x:Name="SmartCleanDesc"
                                       Text="Analyse intelligente — trouve les 3 meilleurs gains en 5 secondes"
                                       FontSize="11" Foreground="#CCFFCC"
                                       Margin="0,3,0,0"/>
                            <TextBlock x:Name="SmartCleanResult"
                                       Text="" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" Margin="0,6,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="SmartScanBtn"
                                    Content="🔍  Analyser"
                                    Background="#FFFFFF20" Foreground="White"
                                    BorderThickness="0" Padding="14,8"
                                    Cursor="Hand" Margin="0,0,10,0"
                                    Click="SmartScan_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="SmartCleanBtn"
                                    Content="⚡  Nettoyer automatiquement"
                                    Background="White" Foreground="#107C10"
                                    BorderThickness="0" Padding="14,8"
                                    FontWeight="SemiBold" Cursor="Hand"
                                    IsEnabled="False"
                                    Click="SmartClean_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Opacity="{TemplateBinding Opacity}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="bg" Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- HEADER : nom plugin + status -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="PluginTitle"
                                   Text="Fichiers temporaires système"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="PluginDescription"
                                   Text="Analyse %TEMP%, Windows\Temp et Prefetch"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecond}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               x:Name="StatusText"
                               Text="Prêt"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecond}"
                               VerticalAlignment="Bottom"/>
                </Grid>

                <!-- OPTIONS NAVIGATEUR (Chrome/Edge/Brave) -->
                <Border x:Name="BrowserOptionsPanel" Grid.Row="2"
                        Background="{DynamicResource BgCard}"
                        CornerRadius="10" Padding="16,12"
                        Margin="0,0,0,14"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Choisir ce qu'il faut analyser / nettoyer :"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,8"/>
                        <WrapPanel>
                            <CheckBox x:Name="OptCache" Content="Cache"
                                      Margin="0,4,20,4" Checked="BrowserOpt_Changed" Unchecked="BrowserOpt_Changed"/>
                            <CheckBox x:Name="OptCodeCache" Content="Code Cache"
                                      Margin="0,4,20,4" Checked="BrowserOpt_Changed" Unchecked="BrowserOpt_Changed"/>
                            <CheckBox x:Name="OptGpuCache" Content="Cache GPU"
                                      Margin="0,4,20,4" Checked="BrowserOpt_Changed" Unchecked="BrowserOpt_Changed"/>
                            <CheckBox x:Name="OptServiceWorkers" Content="Service Workers"
                                      Margin="0,4,20,4" Checked="BrowserOpt_Changed" Unchecked="BrowserOpt_Changed"/>
                            <CheckBox x:Name="OptCookies" Content="Cookies"
                                      Margin="0,4,20,4" Checked="BrowserOpt_Changed" Unchecked="BrowserOpt_Changed"/>
                            <CheckBox x:Name="OptHistory" Content="Historique"
                                      Margin="0,4,20,4" Checked="BrowserOpt_Changed" Unchecked="BrowserOpt_Changed"/>
                            <CheckBox x:Name="OptFavicons" Content="Favicons"
                                      Margin="0,4,20,4" Checked="BrowserOpt_Changed" Unchecked="BrowserOpt_Changed"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- STATS CARD -->
                <Border Grid.Row="3"
                        Background="{DynamicResource BgCard}"
                        CornerRadius="10"
                        Padding="20,14"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="StatFiles" Text="—"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="{DynamicResource Accent}"/>
                            <TextBlock Text="Éléments trouvés"
                                       FontSize="11" Foreground="{DynamicResource TextSecond}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="StatSize" Text="—"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Espace libérable"
                                       FontSize="11" Foreground="{DynamicResource TextSecond}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="StatRisk" Text="—"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="{DynamicResource RiskSafe}"/>
                            <TextBlock Text="Niveau de risque"
                                       FontSize="11" Foreground="{DynamicResource TextSecond}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- PROGRESSBAR FINE -->
                <ProgressBar Grid.Row="4"
                             x:Name="ProgressBar"
                             Style="{StaticResource ModernProgressBar}"
                             Margin="0,0,0,12"
                             Value="0"
                             Visibility="Collapsed"/>

                <!-- LISTE DES RÉSULTATS -->
                <Border Grid.Row="5"
                        Background="{DynamicResource BgCard}"
                        CornerRadius="10"
                        Padding="4">
                    <StackPanel x:Name="ResultsPanel" Opacity="1">
                        <ListView x:Name="FilesListView"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ItemContainerStyle="{StaticResource FileListItemStyle}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  MaxHeight="450">
                            <ListView.View>
                                <GridView>
                                    <!-- Badge risque -->
                                    <GridViewColumn Header="  " Width="36">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Ellipse Width="10" Height="10"
                                                         Fill="{Binding RiskLevel, Converter={x:Static local:RiskColorConverter.Instance}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Chemin" Width="380">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Path}"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Taille" Width="90">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Size, Converter={x:Static local:BytesConverter.Instance}}"
                                                           Foreground="{DynamicResource TextSecond}"
                                                           FontSize="12"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Description" Width="240">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="{DynamicResource TextSecond}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Risque" Width="90">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Padding="6,2"
                                                        Background="{Binding RiskLevel, Converter={x:Static local:RiskBgConverter.Instance}}">
                                                    <TextBlock Text="{Binding RiskLevel, Converter={x:Static local:RiskLabelConverter.Instance}}"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                </Border>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <!-- ÉTAT VIDE -->
                        <StackPanel x:Name="EmptyState"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="0,60"
                                    Visibility="Visible">
                            <TextBlock Text="🔍"
                                       FontSize="42"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Lance une analyse pour voir les éléments nettoyables"
                                       Foreground="{DynamicResource TextSecond}"
                                       FontSize="13"
                                       Margin="0,10,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- OVERLAY CHARGEMENT (par-dessus la liste) -->
                <Border Grid.Row="5"
                        x:Name="LoadingOverlay"
                        Background="{DynamicResource BgCard}"
                        CornerRadius="10"
                        Visibility="Collapsed"
                        Panel.ZIndex="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Spinner arc -->
                        <Grid Width="52" Height="52" Margin="0,0,0,18">
                            <Ellipse Width="52" Height="52"
                                     Stroke="{DynamicResource Border}"
                                     StrokeThickness="4"
                                     Fill="Transparent"/>
                            <Path x:Name="SpinnerArc"
                                  Stroke="{DynamicResource Accent}"
                                  StrokeThickness="4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M 26,2 A 24,24 0 0 1 50,26"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="SpinnerRotate" Angle="0"
                                                     CenterX="26" CenterY="26"/>
                                </Path.RenderTransform>
                            </Path>
                        </Grid>
                        <!-- Texte dynamique -->
                        <TextBlock x:Name="LoadingText"
                                   Text="Analyse en cours…"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="LoadingSubText"
                                   Text="Scan des fichiers, merci de patienter"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecond}"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- BARRE D'ACTIONS -->
                <Border Grid.Row="6"
                        Background="{DynamicResource BgCard}"
                        CornerRadius="10"
                        Padding="16,12"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   x:Name="ActionStatus"
                                   Text=""
                                   Foreground="{DynamicResource TextSecond}"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="AnalyzeBtn"
                                    Content="🔍  Analyser"
                                    Style="{StaticResource SecondBtnStyle}"
                                    Click="Analyze_Click"
                                    Margin="0,0,10,0"/>
                            <Button x:Name="CleanBtn"
                                    Content="🧹  Nettoyer"
                                    Style="{StaticResource AccentBtnStyle}"
                                    Click="Clean_Click"
                                    IsEnabled="False"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Border>
</Window>
