<Window x:Class="OpenCleaner.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenCleaner" Height="600" Width="900">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="OpenCleaner" FontSize="32" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Sélecteur de plugin -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Module :" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="PluginComboBox" Width="300" SelectedIndex="0">
                <ComboBoxItem Tag="system">🧹 Fichiers temporaires système</ComboBoxItem>
                <ComboBoxItem Tag="browser">🌐 Cache navigateurs (Chrome/Edge)</ComboBoxItem>
                <ComboBoxItem Tag="registry">⚠️ Registre (Expert)</ComboBoxItem>
                <ComboBoxItem Tag="steam">🎮 Steam (cache &amp; workshops)</ComboBoxItem>
                <ComboBoxItem Tag="windowsupdate">🔄 Windows Update (SoftwareDistribution)</ComboBoxItem>
                <ComboBoxItem Tag="office">📄 Microsoft Office (cache &amp; AutoRecover)</ComboBoxItem>
                <ComboBoxItem Tag="thumbnails">🖼️ Cache miniatures Windows</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <TextBlock Grid.Row="2" x:Name="StatusText" Text="Prêt" FontSize="14" Foreground="Gray" Margin="0,0,0,10"/>

        <ListView Grid.Row="3" x:Name="FilesListView" Margin="0,10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Élément" DisplayMemberBinding="{Binding Path}" Width="400"/>
                    <GridViewColumn Header="Taille" DisplayMemberBinding="{Binding Size, StringFormat={}{0:N0} octets}" Width="100"/>
                    <GridViewColumn Header="Description" DisplayMemberBinding="{Binding Description}" Width="250"/>
                </GridView>
            </ListView.View>
        </ListView>

        <ProgressBar Grid.Row="4" x:Name="ProgressBar" Height="20" Margin="0,10" Visibility="Collapsed"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="RestoreWindowBtn" Content="🛡️ Restauration" Click="OpenRestore_Click" Padding="20,10" Margin="0,0,10,0"/>
            <Button x:Name="AnalyzeBtn" Content="Analyser" Click="Analyze_Click" Padding="20,10" Margin="0,0,10,0"/>
            <Button x:Name="CleanBtn" Content="Nettoyer" Click="Clean_Click" Padding="20,10" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
